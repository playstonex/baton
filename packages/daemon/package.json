{
  "name": "@flowwhips/daemon",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "bin": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "postinstall": "chmod +x ../../node_modules/.pnpm/node-pty@*/node_modules/node-pty/prebuilds/darwin-*/spawn-helper 2>/dev/null || true",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@flowwhips/shared": "workspace:*",
    "@hono/node-server": "^1.14.0",
    "hono": "^4.7.0",
    "node-pty": "^1.0.0",
    "ws": "^8.18.0",
    "chokidar": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/ws": "^8.18.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3"
  }
}
